FIREWORKS_API_KEY=replace-with-your-fireworks-key
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_VISION_MODEL=accounts/fireworks/models/qwen3p7-plus
FIREWORKS_TEXT_MODEL=accounts/fireworks/models/qwen3p7-plus
FIREWORKS_JUDGE_MODEL=accounts/fireworks/models/kimi-k2p7-code
CLAPTION_MAX_FRAMES=8
CLAPTION_REPAIR_THRESHOLD=8.0
# Keep disabled for automated scoring speed. Set to 1 for slower self-judge/repair demos.
CLAPTION_ENABLE_INTERNAL_JUDGE=0
# Offline demos only. Keep unset for hackathon judging.
# CLAPTION_ALLOW_FALLBACK=1
